{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Syntagmax",
    "patterns": [
        {
            "match": "\\b(artifact)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
            "captures": {
                "1": { "name": "keyword.control.syntagmax" },
                "2": { "name": "entity.name.type.syntagmax" }
            }
        },
        {
            "match": "\\b(attribute)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
            "captures": {
                "1": { "name": "keyword.control.syntagmax" },
                "2": { "name": "variable.other.member.syntagmax" }
            }
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#comments"
        }
    ],
    "repository": {
        "keywords": {
            "patterns": [
                {
                    "match": "\\b(reference)\\s+(to)\\s+(parent)\\b",
                    "captures": {
                        "1": { "name": "support.type.syntagmax" },
                        "2": { "name": "keyword.control.syntagmax" },
                        "3": { "name": "keyword.control.syntagmax" }
                    }
                },
                {
                    "name": "keyword.control.syntagmax",
                    "match": "\\b(artifact|attribute|is|trace|from|to|or|via)\\b"
                },
                {
                    "name": "keyword.other.syntagmax",
                    "match": "\\b(mandatory|optional|multiple|commit|timestamp)\\b"
                },
                {
                    "name": "support.type.syntagmax",
                    "match": "\\b(string|integer|boolean|reference|enum)\\b"
                }
            ]
        },
        "strings": {
            "name": "string.quoted.double.syntagmax",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "constant.character.escape.syntagmax",
                    "match": "\\\\."
                }
            ]
        },
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.number-sign.syntagmax",
                    "match": "#.*$"
                }
            ]
        }
    },
    "scopeName": "source.syntagmax"
}